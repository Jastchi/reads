<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Reads" }}</title>
  <link rel="icon" type="image/png" href="{{ '/images/favicon.png' | url }}">
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css">
</head>
<body>
  <div class="layout">
    <div class="main-col">
      <header class="site-header">
        <h1 class="site-name">Reads</h1>
        <p class="site-tagline">Notes on things I find interesting</p>
      </header>
      <main>
        {{ content | safe }}
      </main>
    </div>
    <aside class="sidebar">
      <div class="sidebar-tags">
        {% set allTopics = [] %}
        {% for post in collections.post %}
          {% if post.data.topics %}
            {% for topic in post.data.topics %}
              {% if topic not in allTopics %}
                {% set allTopics = (allTopics.push(topic), allTopics) %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}
        {% set tagOrder = ["economics", "politics", "history", "sociology", "biology", "philosophy", "book"] %}
        {% for tag in tagOrder %}
          {% if tag in allTopics %}
          <button class="sidebar-tag" data-tag="{{ tag }}">{{ tag }}</button>
          {% endif %}
        {% endfor %}
      </div>
      <nav class="post-index">
        <ul id="index-list">
          {% for post in collections.post | reverse %}
          <li{% if loop.index > 10 %} class="index-overflow"{% endif %} data-topics="{{ post.data.topics | join(' ') if post.data.topics else '' }}">
            <a href="#{{ post.fileSlug }}">{{ post.data.title }}</a>
          </li>
          {% endfor %}
        </ul>
        {% if collections.post | length > 10 %}
        <button class="index-expand" id="index-expand-btn">Show all</button>
        {% endif %}
      </nav>
    </aside>
  </div>
  <script>
    window.addEventListener('load', function () {
      if (window.location.hash) {
        var el = document.getElementById(window.location.hash.slice(1));
        if (el) el.scrollIntoView();
      }
    });

    var btn = document.getElementById('index-expand-btn');
    if (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.index-overflow').forEach(function (el) {
          el.style.display = 'block';
        });
        btn.remove();
      });
    }

    var activeTag = null;

    function filterByTag(tag) {
      var posts = document.querySelectorAll('article.post');
      var indexItems = document.querySelectorAll('#index-list li');
      posts.forEach(function (post) {
        var topics = post.dataset.topics ? post.dataset.topics.split(' ') : [];
        post.style.display = (!tag || topics.includes(tag)) ? '' : 'none';
      });
      indexItems.forEach(function (li) {
        var topics = li.dataset.topics ? li.dataset.topics.split(' ') : [];
        li.style.display = (!tag || topics.includes(tag)) ? '' : 'none';
      });
      document.querySelectorAll('.sidebar-tag').forEach(function (btn) {
        btn.classList.toggle('sidebar-tag--active', btn.dataset.tag === tag);
      });
      document.querySelectorAll('.tag').forEach(function (btn) {
        btn.classList.toggle('tag--active', btn.dataset.tag === tag);
      });
    }

    document.querySelectorAll('.sidebar-tag').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var tag = btn.dataset.tag;
        activeTag = (activeTag === tag) ? null : tag;
        filterByTag(activeTag);
      });
    });

    document.querySelectorAll('.tag').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var tag = btn.dataset.tag;
        activeTag = (activeTag === tag) ? null : tag;
        filterByTag(activeTag);
      });
    });
  </script>
</body>
</html>
